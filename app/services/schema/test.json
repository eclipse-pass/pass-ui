{
    "checkErrorsMode": "onValueChanged",
    "elements": [
        {
            "name": "title",
            "type": "text",
            "title": "Article / Manuscript Title",
            "isRequired": true,
            "requiredErrorText": "Title must be provided"
        },
        {
            "name": "journal-title",
            "type": "text",
            "title": "Journal title"
        },
        {
            "name": "volume",
            "type": "text",
            "title": "Journal Volume"
        },
        {
            "name": "issue",
            "type": "text",
            "title": "Journal issue"
        },
        {
            "name": "issns",
            "type": "paneldynamic",
            "title": "ISSN information for the manuscript's journal",
            "templateElements": [
                {
                    "name": "issn",
                    "type": "text",
                    "title": "ISSN"
                },
                {
                    "name": "pubType",
                    "type": "dropdown",
                    "title": "publication type",
                    "choices": [
                        "Print",
                        "Online"
                    ]
                }
            ]
        },
        {
            "name": "publisher",
            "type": "text",
            "title": "Publisher"
        },
        {
            "name": "publicationDate",
            "type": "text",
            "title": "Publication date",
            "inputType": "date"
        },
        {
            "name": "abstract",
            "type": "comment",
            "title": "The abstract of the article or manuscript being submitted"
        },
        {
            "name": "authors",
            "type": "paneldynamic",
            "title": "Authors of this article or manuscript",
            "templateElements": [
                {
                    "name": "author",
                    "type": "text",
                    "title": "Author"
                },
                {
                    "name": "orcid",
                    "type": "text",
                    "title": "ORCID"
                }
            ]
        },
        {
            "name": "under-embargo",
            "type": "boolean",
            "title": "Under Embargo"
        },
        {
            "name": "Embargo-end-date",
            "type": "text",
            "title": "Embargo end date",
            "inputType": "date"
        }
    ]
}
