{
  "name": "pass-ui",
  "version": "2.6.0-SNAPSHOT",
  "private": true,
  "description": "The user interface for the eclipse-pass project",
  "license": "Apache-2.0",
  "author": "",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "repository": "",
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:docker": "docker build --no-cache -t ghcr.io/eclipse-pass/pass-ui:$npm_package_version .",
    "build:latest": "docker build --no-cache -t ghcr.io/eclipse-pass/pass-ui:latest .",
    "lint": "concurrently \"npm:lint:*(!fix)\" --names \"lint:\"",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "concurrently \"npm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"npm:lint:*:fix\" --names \"fix:\"",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "typecheck": "ember-tsc --noEmit",
    "start": "vite",
    "start:production": "vite build && vite preview --port 4200 --host",
    "test": "concurrently \"npm:lint\" \"npm:test:ember\" --names \"lint,test:\"",
    "test:ember": "vite build --mode development && ember test --path dist",
    "test:visual": "npx playwright test",
    "test:visual:update": "npx playwright test --update-snapshots",
    "prepare": "husky install",
    "create_sbom": "FETCH_LICENSE=true cdxgen --required-only --no-babel --type pnpm -o pass-ui-$npm_package_version-cyclonedx-sbom.json"
  },
  "dependencies": {
    "@ember-data/json-api": "~5.8.1",
    "@ember-data/model": "~5.8.1",
    "@ember-data/request": "~5.8.1",
    "@ember-data/request-utils": "~5.8.1",
    "@ember-data/serializer": "~5.8.1",
    "@ember-data/store": "~5.8.1",
    "@ember/string": "^4.0.1",
    "@fortawesome/ember-fontawesome": "^3.0.0",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@glimmer/component": "^2.0.0",
    "@glimmer/tracking": "^1.1.2",
    "@warp-drive/ember": "5.8.1",
    "@warp-drive/utilities": "5.8.1",
    "bootstrap": "5.0.0",
    "ember-basic-dropdown": "^8.0.0",
    "ember-concurrency": "^5.1.0",
    "ember-file-upload": "^9.5.0",
    "ember-inflector": "^6.0.0",
    "ember-load-initializers": "^3.0.0",
    "ember-modifier": "^4.2.0",
    "ember-page-title": "^9.0.3",
    "ember-power-select": "^8.12.1",
    "ember-resolver": "^13.0.0",
    "ember-simple-auth": "^8.3.0",
    "survey-core": "^2.0.0",
    "survey-js-ui": "^2.0.0",
    "sweetalert2": "11.17.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/eslint-parser": "^7.24.7",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.24.7",
    "@babel/plugin-transform-runtime": "^7.26.9",
    "@babel/runtime": "^7.29.2",
    "@babel/plugin-transform-typescript": "^7.26.0",
    "@cyclonedx/cdxgen": "^11.0.3",
    "@ember-data-types/graph": "5.8.1",
    "@ember-data-types/json-api": "5.8.1",
    "@ember-data-types/model": "5.8.1",
    "@ember-data-types/request": "5.8.1",
    "@ember-data-types/serializer": "5.8.1",
    "@ember-data-types/store": "5.8.1",
    "@ember/optional-features": "^3.0.0",
    "@ember/test-helpers": "^5.4.1",
    "@ember/test-waiters": "^4.0.0",
    "@embroider/compat": "^4.1.17",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.4.7",
    "@embroider/vite": "^1.7.2",
    "@eslint/js": "^9.37.0",
    "@faker-js/faker": "^8.4.1",
    "@glint/ember-tsc": "^1.1.1",
    "@glint/template": "^1.7.4",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-babel": "^6.0.4",
    "@tsconfig/ember": "^3.0.12",
    "@types/qunit": "^2.19.13",
    "@types/rsvp": "4.0.9",
    "@warp-drive/build-config": "5.8.1",
    "@warp-drive/core-types": "5.8.1",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "babel-plugin-ember-template-compilation": "^3.1.0",
    "clean-css": "^5.3.3",
    "concurrently": "^8.2.2",
    "decorator-transforms": "^2.3.0",
    "ember-auto-import": "^2.7.4",
    "ember-cli": "~6.12.0",
    "ember-cli-babel": "^8.2.0",
    "ember-cli-dependency-lint": "^2.0.1",
    "ember-cli-deprecation-workflow": "^3.4.0",
    "ember-cli-flash": "^7.0.0",
    "ember-cli-htmlbars": "^6.3.0",
    "ember-cli-typescript": "^5.3.0",
    "ember-data-types": "5.8.1",
    "ember-mirage": "^0.4.3",
    "ember-provide-consume-context": "^0.8.0",
    "ember-qunit": "^9.0.0",
    "ember-sinon-qunit": "^7.4.0",
    "ember-source": "~6.12.0",
    "ember-template-lint": "^7.9.3",
    "ember-template-lint-plugin-prettier": "^5.0.0",
    "ember-test-selectors": "^6.0.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^12.7.4",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-qunit": "^8.2.5",
    "globals": "^16.4.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.3.0",
    "merge": "^2.1.1",
    "miragejs": "^0.1.48",
    "prettier": "^3.8.1",
    "prettier-plugin-ember-template-tag": "^2.1.3",
    "qunit": "^2.25.0",
    "qunit-dom": "^3.2.0",
    "sinon": "^15.2.0",
    "stylelint": "^16.6.1",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-prettier": "^5.0.0",
    "tracked-built-ins": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vite": "^7.0.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts,gjs,gts}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">= 24"
  },
  "ember": {
    "edition": "octane"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@^1": "^1.1.12",
      "brace-expansion@^2": "^2.0.2",
      "handlebars": ">=4.7.9"
    }
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  }
}
